generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Pengguna {
    id_pengguna   Int         @id @default(autoincrement())
    nama_lengkap  String      @db.VarChar(100)
    email         String      @unique @db.VarChar(100)
    password_hash String      @db.VarChar(255)
    role          String      @db.VarChar(50)
    created_at    DateTime    @default(now())
    updated_at    DateTime
    transaksi     Transaksi[]
    auditLog      AuditLog[]  // ← tambah ini

    @@map("pengguna")
}

model Barang {
  id_barang      Int         @id @default(autoincrement())
  nama_barang    String      @db.VarChar(150)
  sku            String      @unique @db.VarChar(50)
  kategori       String?     @db.VarChar(100)
  satuan         String      @db.VarChar(50)
  kuantitas_stok Int         @default(0)
  batas_minimum  Int         @default(0)
  created_at     DateTime    @default(now())
  updated_at     DateTime
  harga          BigInt      @default(0)
  transaksi      Transaksi[]

  @@map("barang")
}

model Transaksi {
  id_transaksi    Int      @id @default(autoincrement())
  id_barang       Int
  id_pengguna     Int
  tanggal         DateTime @default(now())
  jenis_transaksi String   @db.VarChar(20)
  jumlah          Int
  keterangan      String?
  created_at      DateTime @default(now())
  barang          Barang   @relation(fields: [id_barang], references: [id_barang], onDelete: Cascade)
  pengguna        Pengguna @relation(fields: [id_pengguna], references: [id_pengguna], onDelete: SetNull)

  @@index([id_barang])
  @@index([id_pengguna])
  @@index([tanggal])
  @@map("transaksi")
}

model AuditLog {
  id_log      Int       @id @default(autoincrement())
  id_pengguna Int?
  aksi        String    @db.VarChar(200)
  created_at  DateTime  @default(now())
  pengguna    Pengguna? @relation(fields: [id_pengguna], references: [id_pengguna], onDelete: SetNull)

  @@map("audit_log")
}